# AI Capital Management - Environment Variables
# Copy this file to .env and fill in your values

# Database (auto-configured via docker-compose)
DATABASE_URL=postgresql://ai_user:ai_password@db:5432/ai_capital

# Security - generate a random 32+ char string
SECRET_KEY=your-very-secret-key-minimum-32-characters-long

# Groq AI API Key (free tier available)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Alpha Vantage Market Data (free tier)
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=TMPW23EHFMN4Y7XI

# OpenAI API Key (optional, not required)
OPENAI_API_KEY=optional_not_required
