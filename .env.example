# ============================================================
# AI Capital Management — Переменные окружения
# Этап 0, Сессия 0.1
# ============================================================
# Скопируйте этот файл в .env и заполните значения:
#   copy .env.example .env  (Windows PowerShell)
# ============================================================

# ── ОБЯЗАТЕЛЬНЫЕ ──

# Секретный ключ для JWT-токенов (минимум 32 символа!)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── База данных ──
# Для Docker Compose (по умолчанию):
DATABASE_URL=postgresql://ai_user:ai_password@db:5432/ai_capital

# Пароль PostgreSQL (используется в docker-compose.yml)
POSTGRES_PASSWORD=ai_password

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── AI провайдеры ──
# Groq (бесплатный, основной для MVP)
GROQ_API_KEY=

# Google Gemini (бесплатный уровень)
# GEMINI_API_KEY=

# OpenAI (опционально)
# OPENAI_API_KEY=

# Alpha Vantage (для рыночных данных)
# ALPHA_VANTAGE_API_KEY=

# ── CORS ──
# Разрешённые origins через запятую (без пробелов после запятой)
# Для локальной разработки:
CORS_ORIGINS=http://localhost:3000,http://localhost:10000

# Для production (Render):
# CORS_ORIGINS=https://ai-capital-frontend.onrender.com,http://localhost:3000

# ── Режим отладки ──
# true = включает /docs и /redoc
# false = отключает Swagger UI в production
DEBUG=true
