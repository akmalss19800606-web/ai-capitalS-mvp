[
  {
    "id": "posc_001",
    "rule_name": "Prohibition of Riba (Interest)",
    "category": "financial_prohibition",
    "description": "All forms of interest-based transactions are prohibited. Returns must come from real economic activity.",
    "severity": "critical",
    "applicable_products": ["all"],
    "references": ["Quran 2:275", "Quran 3:130"]
  },
  {
    "id": "posc_002",
    "rule_name": "Prohibition of Gharar (Excessive Uncertainty)",
    "category": "financial_prohibition",
    "description": "Contracts must have clear terms, known price, and defined deliverables. Excessive uncertainty invalidates contracts.",
    "severity": "critical",
    "applicable_products": ["all"],
    "references": ["Sahih Muslim 1513"]
  },
  {
    "id": "posc_003",
    "rule_name": "Prohibition of Maysir (Gambling)",
    "category": "financial_prohibition",
    "description": "Speculative transactions resembling gambling are forbidden. Investment must be based on real assets.",
    "severity": "critical",
    "applicable_products": ["all"],
    "references": ["Quran 5:90"]
  },
  {
    "id": "posc_004",
